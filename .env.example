# Supabase project (used for both the Postgres connection and Storage)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Postgres connection — use the Supabase connection pooler (port 6543),
# required for serverless (Vercel functions open many short-lived connections)
DATABASE_URL=

# Auth — REQUIRED in any deployed environment (the app refuses to start
# without it there, rather than silently signing sessions with the public
# default secret in this file). Set a long random value.
JWT_SECRET=

# Optional: session lifetime in hours (default 24). Logging out (or changing
# password) revokes the session everywhere immediately regardless of this.
SESSION_MAX_AGE_HOURS=24

# CEO seed account (created on first `pnpm run migrate` / build). Set before
# the first deploy, or the account is created with the public default
# ceo@latechs.org / ChangeMe123! (must-change-password is enforced, but log
# in and change it immediately either way)
CEO_EMAIL=
CEO_PASSWORD=

# Required to authorize Vercel's daily cron hit to /api/cron/reminders
CRON_SECRET=

# Optional: transactional email (silently disabled if unset)
RESEND_API_KEY=
EMAIL_FROM=
APP_URL=

# Cloudflare R2 (attachment storage — S3-compatible object storage, not
# Supabase, so uploads survive Vercel's read-only serverless filesystem)
# Credentials come from Cloudflare dashboard -> R2 -> Manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=latech

# Optional: local dev server port for `pnpm run server` (default 5184).
# Not used on Vercel — the serverless function has no fixed port.
PORT_API=5184

# Optional: TURN relay for video meetings. Most peer connections work with
# the built-in STUN alone; set these only if two participants on heavily
# firewalled networks (symmetric NAT / CGNAT) can't get audio/video.
# Free tiers exist (e.g. metered.ca, Twilio NTS). Vended to signed-in
# clients via GET /api/meetings/ice-servers — never baked into the bundle.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
